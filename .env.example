NODE_ENV=development
NODE_OPTIONS=--dns-result-order=ipv4first
APP_BASE_URL=http://localhost:3000
APP_PUBLIC_URL=https://family.example.ru

# PostgreSQL
DATABASE_URL=postgresql://family_ai:family_ai@localhost:5432/family_ai

# Redis-compatible queue/cache. Optional for local MVP if using Postgres jobs.
REDIS_URL=redis://localhost:6379

# Timeweb AI
TIMEWEB_AI_API_KEY=replace_me
TIMEWEB_AI_BASE_URL=https://agent.timeweb.cloud
TIMEWEB_DEFAULT_MODEL=auto
# Either provide one JSON map or individual TIMEWEB_AGENT_* variables.
TIMEWEB_AGENT_IDS={"family_dispatcher":"replace_me","owner_assistant":"replace_me","shopping_assistant":"replace_me","design_assistant":"replace_me","teacher_methodologist":"replace_me","teacher_secretary":"replace_me","materials_librarian":"replace_me","communication_assistant":"replace_me","daughter_tutor":"replace_me","daughter_english_coach":"replace_me","scheduler":"replace_me"}
TIMEWEB_AGENT_FAMILY_DISPATCHER=replace_me
TIMEWEB_AGENT_OWNER_ASSISTANT=replace_me
TIMEWEB_AGENT_SHOPPING_ASSISTANT=replace_me
TIMEWEB_AGENT_DESIGN_ASSISTANT=replace_me
TIMEWEB_AGENT_TEACHER_METHODOLOGIST=replace_me
TIMEWEB_AGENT_TEACHER_SECRETARY=replace_me
TIMEWEB_AGENT_MATERIALS_LIBRARIAN=replace_me
TIMEWEB_AGENT_COMMUNICATION_ASSISTANT=replace_me
TIMEWEB_AGENT_DAUGHTER_TUTOR=replace_me
TIMEWEB_AGENT_DAUGHTER_ENGLISH_COACH=replace_me
TIMEWEB_AGENT_SCHEDULER=replace_me

# Telegram bots
TELEGRAM_BOT_TOKEN=replace_me
TELEGRAM_OWNER_BOT_TOKEN=replace_me
TELEGRAM_DAUGHTER_BOT_TOKEN=replace_me
TELEGRAM_TEACHER_BOT_TOKEN=replace_me
TELEGRAM_WEBHOOK_SECRET=replace_with_random_secret
TELEGRAM_OWNER_WEBHOOK_SECRET=replace_with_random_secret
TELEGRAM_DAUGHTER_WEBHOOK_SECRET=replace_with_random_secret
TELEGRAM_TEACHER_WEBHOOK_SECRET=replace_with_random_secret
TELEGRAM_DROP_PENDING_UPDATES=false
TELEGRAM_REPLY_MODE=webhook_response
TELEGRAM_REQUIRE_WEBHOOK_SECRET=true

# Tools / capabilities
WEATHER_TIMEOUT_MS=6000
APP_DEFAULT_LOCATION=Москва
APP_DEFAULT_TIME_ZONE=Europe/Moscow

# Speech-to-text for Telegram voice messages.
# Default: local Vosk in the same Docker container, no external paid API.
VOICE_TRANSCRIPTION_PROVIDER=local_vosk
VOSK_MODEL_PATH=/opt/vosk/model
VOSK_PYTHON_PATH=python3
VOSK_TRANSCRIPTION_TIMEOUT_MS=25000

# Optional external speech-to-text endpoint fallback.
# The endpoint should accept multipart/form-data with a `file` field and return JSON:
# { "text": "recognized speech" }
VOICE_TRANSCRIPTION_URL=
VOICE_TRANSCRIPTION_API_KEY=
VOICE_TRANSCRIPTION_MODEL=
VOICE_TRANSCRIPTION_LANGUAGE=ru

# Optional Telegram relay, used when Telegram -> Timeweb direct ingress is unstable.
# TELEGRAM_RELAY_URL and TELEGRAM_RELAY_SECRET are Timeweb app env values.
# TELEGRAM_RELAY_UPSTREAM_SECRET must also be set in the relay when enabled.
TIMEWEB_APP_URL=https://griff35victorov-ai-fam-8853.twc1.net
TELEGRAM_RELAY_URL=https://family-ai-telegram-relay.example.workers.dev
TELEGRAM_RELAY_SECRET=replace_with_random_secret
TELEGRAM_RELAY_UPSTREAM_SECRET=replace_with_random_secret
RELAY_ACK_TEXT=Запрос получен.
TIMEWEB_RESPONSE_TIMEOUT_MS=1200
TIMEWEB_BACKGROUND_TIMEOUT_MS=5000
TIMEWEB_FORWARD_RETRIES=2
TIMEWEB_FORWARD_RETRY_DELAY_MS=250
TELEGRAM_SEND_MAX_ATTEMPTS=3
TELEGRAM_SEND_RETRY_DELAY_MS=500

# Production bootstrap. Keep disabled unless intentionally writing users.
# Telegram access is granted by User.telegramUserId records, not by TELEGRAM_ALLOWED_USER_IDS.
FAMILY_AI_BOOTSTRAP_USERS=[{"id":"owner","role":"owner","displayName":"Owner","telegramUserId":"111111111"}]
FAMILY_AI_BOOTSTRAP_USERS_ALLOW_WRITE=0

# Object storage
S3_ENDPOINT=replace_me
S3_REGION=ru-1
S3_BUCKET=family-ai-materials
S3_ACCESS_KEY_ID=replace_me
S3_SECRET_ACCESS_KEY=replace_me

# Security
SESSION_SECRET=replace_with_32_plus_random_chars
ENCRYPTION_KEY=replace_with_32_byte_base64_key

# Cost controls
MONTHLY_AI_BUDGET_RUB=12000
DAILY_OWNER_LIMIT_RUB=250
DAILY_CHILD_LIMIT_RUB=150
DAILY_TEACHER_LIMIT_RUB=350

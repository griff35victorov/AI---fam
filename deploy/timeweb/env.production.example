APP_ENV=production
NODE_OPTIONS=--dns-result-order=ipv4first
APP_PUBLIC_URL=https://griff35victorov-ai-fam-8853.twc1.net
PORT=8080
APP_SECRET=replace_me
ENCRYPTION_KEY=replace_me

DATABASE_URL=postgresql://user:password@host:5432/family_ai?schema=public
# If TLS is enabled for the PostgreSQL cluster in Timeweb, use the connection
# parameters from the Timeweb "Connection" tab instead of this plain URL.

S3_ENDPOINT=https://s3.twcstorage.ru
S3_REGION=ru-1
S3_BUCKET=family-ai-prod
S3_ACCESS_KEY_ID=replace_me
S3_SECRET_ACCESS_KEY=replace_me
S3_FORCE_PATH_STYLE=true

TIMEWEB_AI_BASE_URL=https://agent.timeweb.cloud
TIMEWEB_AI_API_KEY=replace_me
TIMEWEB_AGENT_IDS={"family_dispatcher":"replace_me","owner_assistant":"replace_me","shopping_assistant":"replace_me","design_assistant":"replace_me","teacher_methodologist":"replace_me","teacher_secretary":"replace_me","materials_librarian":"replace_me","communication_assistant":"replace_me","daughter_tutor":"replace_me","daughter_english_coach":"replace_me","scheduler":"replace_me"}
TIMEWEB_AGENT_FAMILY_DISPATCHER=replace_me
TIMEWEB_AGENT_OWNER_ASSISTANT=replace_me
TIMEWEB_AGENT_SHOPPING_ASSISTANT=replace_me
TIMEWEB_AGENT_DESIGN_ASSISTANT=replace_me
TIMEWEB_AGENT_TEACHER_METHODOLOGIST=replace_me
TIMEWEB_AGENT_TEACHER_SECRETARY=replace_me
TIMEWEB_AGENT_MATERIALS_LIBRARIAN=replace_me
TIMEWEB_AGENT_COMMUNICATION_ASSISTANT=replace_me
TIMEWEB_AGENT_DAUGHTER_TUTOR=replace_me
TIMEWEB_AGENT_DAUGHTER_ENGLISH_COACH=replace_me
TIMEWEB_AGENT_SCHEDULER=replace_me

TELEGRAM_BOT_TOKEN=replace_me
TELEGRAM_OWNER_BOT_TOKEN=replace_me
TELEGRAM_DAUGHTER_BOT_TOKEN=replace_me
TELEGRAM_TEACHER_BOT_TOKEN=replace_me
TELEGRAM_WEBHOOK_SECRET=replace_me
TELEGRAM_OWNER_WEBHOOK_SECRET=replace_me
TELEGRAM_DAUGHTER_WEBHOOK_SECRET=replace_me
TELEGRAM_TEACHER_WEBHOOK_SECRET=replace_me
TELEGRAM_DROP_PENDING_UPDATES=false
TELEGRAM_REPLY_MODE=webhook_response

# Telegram access is granted by User.telegramUserId records, not by TELEGRAM_ALLOWED_USER_IDS.
# Keep writes disabled unless intentionally bootstrapping real family Telegram IDs.
FAMILY_AI_BOOTSTRAP_USERS=[{"id":"owner","role":"owner","displayName":"Owner","telegramUserId":"111111111"},{"id":"teacher","role":"teacher","displayName":"Teacher","telegramUserId":"222222222"},{"id":"daughter","role":"family_child","displayName":"Daughter","telegramUserId":"333333333"}]
FAMILY_AI_BOOTSTRAP_USERS_ALLOW_WRITE=0

JWT_SECRET=replace_me
SESSION_COOKIE_NAME=family_ai_session
CORS_ORIGINS=https://family.example.ru

WORKER_CONCURRENCY=2
SCHEDULER_INTERVAL_SECONDS=30
COMPOSE_PROFILES=
JOB_MAX_ATTEMPTS=5
DEFAULT_TIMEZONE=Europe/Moscow

LOG_LEVEL=info
SENTRY_DSN=
REDIS_URL=

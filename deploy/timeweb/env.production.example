APP_ENV=production
APP_PUBLIC_URL=https://family.example.ru
PORT=8080
APP_SECRET=replace_me
ENCRYPTION_KEY=replace_me

DATABASE_URL=postgresql://user:password@host:5432/default_db
PGSSLMODE=require

S3_ENDPOINT=https://s3.twcstorage.ru
S3_REGION=ru-1
S3_BUCKET=family-ai-prod
S3_ACCESS_KEY_ID=replace_me
S3_SECRET_ACCESS_KEY=replace_me
S3_FORCE_PATH_STYLE=true

TIMEWEB_AI_BASE_URL=https://api.timeweb.cloud
TIMEWEB_AI_AGENT_ID=replace_me
TIMEWEB_AI_AGENT_TOKEN=replace_me

TELEGRAM_BOT_TOKEN_MAIN=replace_me
TELEGRAM_ALLOWED_USER_IDS=123,456
TELEGRAM_WEBHOOK_SECRET=replace_me

JWT_SECRET=replace_me
SESSION_COOKIE_NAME=family_ai_session
CORS_ORIGINS=https://family.example.ru

WORKER_CONCURRENCY=2
SCHEDULER_INTERVAL_SECONDS=30
JOB_MAX_ATTEMPTS=5
DEFAULT_TIMEZONE=Europe/Moscow

LOG_LEVEL=info
SENTRY_DSN=
REDIS_URL=
